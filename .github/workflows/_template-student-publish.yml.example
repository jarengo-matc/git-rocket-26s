# ─────────────────────────────────────────────────────────────
# Student Publish Workflow Template
# ─────────────────────────────────────────────────────────────
# SETUP STEPS:
#
# 1. Copy this file to .github/workflows/ and rename it:
#      <your-name>-publish.yml
#    Example: tsteele-publish.yml
#
# 2. Replace YOUR_BRANCH (appears twice below) with your branch name.
#    Example: tsteele/rocket-page
#
# 3. Replace YOUR_FILENAME with your desired HTML filename.
#    Use your name so it doesn't clash with others.
#    Example: tsteele.html
#
# 4. Commit this workflow file to YOUR branch and push.
#    On every push the workflow will open (or update) a pull
#    request to add your rocket page to main's docs/ folder.
#    Once the PR is merged, GitHub Pages will serve your page at:
#    https://<org>.github.io/git-rocket/YOUR_FILENAME
# ─────────────────────────────────────────────────────────────

name: "Publish my rocket page"

env:
  STUDENT_BRANCH: YOUR_BRANCH     # e.g. tsteele/rocket-page
  OUTPUT_FILENAME: YOUR_FILENAME  # e.g. tsteele.html

on:
  push:
    branches:
      - YOUR_BRANCH  # ← must match STUDENT_BRANCH above

permissions:
  contents: write
  pull-requests: write

jobs:
  publish:
    runs-on: ubuntu-latest
    steps:
      - name: Check out student branch
        uses: actions/checkout@v4

      - name: Set up Node
        uses: actions/setup-node@v4
        with:
          node-version: 20
          cache: npm

      - name: Install dependencies
        run: npm ci

      - name: Build rocket HTML
        run: npm run build:docs
        # Generates docs/index.html from your branch's git-rocket.js

      - name: Rename built file to your filename
        run: cp docs/index.html docs/${{ env.OUTPUT_FILENAME }}

      - name: Push built file to publish branch and open PR
        env:
          GH_TOKEN: ${{ secrets.GITHUB_TOKEN }}
        run: |
          PUBLISH_BRANCH="publish/${{ env.OUTPUT_FILENAME }}"

          git config user.email "actions@github.com"
          git config user.name "GitHub Actions"

          git switch -c "$PUBLISH_BRANCH" 2>/dev/null || git switch "$PUBLISH_BRANCH"

          git add docs/${{ env.OUTPUT_FILENAME }}
          git diff --cached --quiet && echo "No changes, skipping PR." && exit 0

          git commit -m "publish: ${{ env.OUTPUT_FILENAME }} from ${{ env.STUDENT_BRANCH }}"
          git push origin "$PUBLISH_BRANCH" --force

          gh pr create \
            --base main \
            --head "$PUBLISH_BRANCH" \
            --title "Publish ${{ env.OUTPUT_FILENAME }} to GitHub Pages" \
            --body "Automated PR from \`${{ env.STUDENT_BRANCH }}\`. Merging will add \`docs/${{ env.OUTPUT_FILENAME }}\` to main and trigger a GitHub Pages deployment." \
          2>/dev/null || echo "PR already exists, updated branch."
