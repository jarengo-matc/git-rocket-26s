# ─────────────────────────────────────────────────────────────
# Student Publish Workflow Template
# ─────────────────────────────────────────────────────────────
# SETUP STEPS:
#
# 1. Copy this file to .github/workflows/ and rename it:
#      <your-name>-publish.yml
#    Example: tsteele-publish.yml
#
# 2. Set YOUR_BRANCH below to the name of YOUR branch.
#    Example: tsteele/rocket-page
#
# 3. Set YOUR_FILENAME below to the HTML filename you want
#    published. Use your name so it doesn't clash with others.
#    Example: tsteele.html
#
# 4. Commit this workflow file to YOUR branch and push.
#    On every push the workflow will open (or update) a pull
#    request to add your rocket page to main's docs/ folder.
#    Once the PR is merged, GitHub Pages will serve your page.
# ─────────────────────────────────────────────────────────────

name: "Publish my rocket page"

env:
  STUDENT_BRANCH: YOUR_BRANCH     # e.g. tsteele/rocket-page
  OUTPUT_FILENAME: YOUR_FILENAME  # e.g. tsteele.html

on:
  push:
    branches:
      - YOUR_BRANCH  # match STUDENT_BRANCH above

permissions:
  contents: write
  pull-requests: write

jobs:
  publish:
    runs-on: ubuntu-latest
    steps:
      - name: Check out student branch
        uses: actions/checkout@v4

      - name: Set up Node
        uses: actions/setup-node@v4
        with:
          node-version: 20
          cache: npm

      - name: Install dependencies
        run: npm ci

      - name: Build rocket HTML
        run: npm run build:docs
        # Generates docs/index.html from your branch's git-rocket.js

      - name: Rename built file to your filename
        run: cp docs/index.html docs/${{ env.OUTPUT_FILENAME }}

      - name: Open or update PR to publish page
        uses: peter-evans/create-pull-request@v7
        with:
          token: ${{ secrets.GITHUB_TOKEN }}
          # Work on a dedicated publish branch so the PR stays tidy
          branch: publish/${{ env.OUTPUT_FILENAME }}
          base: main
          # Move the built file into docs/ under the student's filename
          add-paths: |
            docs/${{ env.OUTPUT_FILENAME }}
          commit-message: "publish: ${{ env.OUTPUT_FILENAME }} from ${{ env.STUDENT_BRANCH }}"
          title: "Publish ${{ env.OUTPUT_FILENAME }} to GitHub Pages"
          body: |
            Automated PR from the `${{ env.STUDENT_BRANCH }}` publish workflow.
            Merging this will add `docs/${{ env.OUTPUT_FILENAME }}` to `main` and
            trigger a GitHub Pages deployment.
          # Re-use the same PR on subsequent pushes instead of opening a new one
          delete-branch: false
